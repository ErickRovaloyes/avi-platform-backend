# AVI Platform — Server Environment Variables
# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=avi_platform

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
